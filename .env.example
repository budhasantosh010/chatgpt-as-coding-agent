# chatgpt-code-harness configuration. Copy to `.env` and edit.
# Only HARNESS_WORKSPACE_ROOTS is really required to be useful.

# Directories ChatGPT is allowed to touch. open_workspace can only open folders
# inside these roots. Separate multiple with ';' on Windows, ':' on macOS/Linux.
#   Windows:      HARNESS_WORKSPACE_ROOTS=C:\Users\you\projects
#   macOS/Linux:  HARNESS_WORKSPACE_ROOTS=/home/you/projects
# Leave blank to default to a safe sandbox dir under the state directory.
HARNESS_WORKSPACE_ROOTS=

# full = read + write + execute (normal coding). read_only = inspection only.
# Only the operator can change this; ChatGPT cannot escalate itself.
HARNESS_MODE=full

# Local bind + port (keep host on localhost; Tailscale Funnel exposes it).
HARNESS_HOST=127.0.0.1
HARNESS_PORT=8848

# Leave blank to auto-generate a stable 256-bit secret route (persisted in the
# state dir). This secret path is the primary auth for the ChatGPT connector.
HARNESS_SECRET_ROUTE=

# Optional defense-in-depth. If set, clients must send Authorization: Bearer <token>.
HARNESS_BEARER_TOKEN=

# Where sessions, logs, and the secret route are stored.
# HARNESS_STATE_DIR=C:\Users\Lenovo\.chatgpt-code-harness

# Shell for run_command. Blank = auto (PowerShell on Windows, bash on POSIX).
# HARNESS_SHELL=

# Output caps and rate limit.
# HARNESS_MAX_OUTPUT_CHARS=30000
# HARNESS_MAX_READ_CHARS=100000
# HARNESS_RATE_LIMIT_PER_MIN=120

# Extra secret-file globs to block from read/write (comma-separated), added to
# the built-in denylist (private keys, .npmrc, .git-credentials, etc.).
# HARNESS_EXTRA_SECRET_GLOBS=*.secret,config/prod.json

# Redact known secret formats (API keys, tokens, private keys) from ALL tool
# output before it reaches ChatGPT. On by default; the harness sends your code
# to a third party, so leave this on unless you have a reason not to.
# HARNESS_SCRUB_OUTPUT=true

# Append every tool call to <state_dir>/audit.jsonl (a durable record of what
# ChatGPT did on your machine). On by default.
# HARNESS_AUDIT_LOG=true

# Execution backend for run_command / start_process.
#   local  = run in your host shell (default; no dependencies)
#   docker = run each command in a throwaway container with only the workspace
#            mounted and networking off (real isolation for untrusted repos).
#            Requires Docker installed and running.
# HARNESS_SANDBOX=local
# HARNESS_SANDBOX_IMAGE=python:3.12-slim
# HARNESS_SANDBOX_NETWORK=none

# Transport tuning (match your working ChatGPT connector if needed).
# HARNESS_STATELESS_HTTP=true
# HARNESS_JSON_RESPONSE=false
